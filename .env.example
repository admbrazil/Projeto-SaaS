# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY: copie cada variavel para o painel Railway → Variables
# LOCAL:   copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# Qual settings usar:
#   Local:   config.settings.development
#   Railway: config.settings.railway
DJANGO_SETTINGS_MODULE=config.settings.railway

# Django
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.telesaas.com.br
EXTRA_ALLOWED_HOSTS=

# Banco de dados (Railway preenche automaticamente com o plugin PostgreSQL)
DATABASE_URL=postgres://usuario:senha@host:5432/nome_banco

# Redis (Railway preenche automaticamente com o plugin Redis)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Criptografia de dados sensiveis (CPF, dados medicos)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Segredo para HMAC dos magic links
MAGIC_LINK_SECRET=change-me-magic-link-secret

# Email SMTP (sem essas variaveis, emails vao para o console/log)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@telesaas.com.br
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Telesaas <noreply@telesaas.com.br>

# Storage S3 (opcional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=telesaas-media
AWS_S3_REGION_NAME=sa-east-1

# Sentry (opcional)
SENTRY_DSN=

# Video / Teleconsulta
VIDEO_PROVIDER=mevo
MEVO_API_KEY=
MEVO_API_URL=https://api.mevo.com.br/v1

# Webhooks
WEBHOOK_SECRET=change-me-webhook-signing-secret

# LGPD
LGPD_RESPONSE_DAYS=15
LGPD_RETENTION_DAYS=30
DPO_EMAIL=dpo@telesaas.com.br
DPO_NAME=Encarregado de Protecao de Dados

# Dominio base
BASE_DOMAIN=telesaas.com.br
